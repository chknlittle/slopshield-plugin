{
  "manifest_version": 3,
  "name": "SlopShield",
  "version": "0.5.0",
  "description": "Hide AI-slop videos from regular YouTube feeds.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://slopshield-api.chkn.computer/*"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "slopshield@chkn.computer",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "websiteContent"
        ],
        "optional": []
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "SlopShield",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/webpo-page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "css": [
        "src/content.css"
      ],
      "js": [
        "src/content-helpers.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
